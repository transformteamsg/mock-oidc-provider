{
  "name": "@transformteamsg/mock-oidc-provider",
  "version": "0.2.0",
  "description": "Local OIDC provider for development and testing.",
  "license": "MIT",
  "keywords": [
    "oidc",
    "oauth2",
    "mock",
    "local-development",
    "pkce"
  ],
  "type": "module",
  "bin": {
    "mock-oidc-provider": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "prepack": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "pnpm pack --dry-run"
  },
  "dependencies": {
    "oauth2-mock-server": "^8.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "jose": "^6.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.11.0"
}
